DATABASE_URL=file:/home/z/my-project/db/custom.db

# Z.ai API Key for AI automation (LLM, image search, etc.)
# Get your key from https://z.ai
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Session secret for admin auth (change in production!)
SESSION_SECRET=change-this-in-production-please-use-random-string

# Cron secret for scheduled jobs (change to random string!)
CRON_SECRET=cron-secret-change-me-to-random

# Public site URL (for SEO: sitemap, RSS, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local development (SQLite)
# Production: use Neon PostgreSQL URL
DATABASE_URL=file:./db/custom.db
