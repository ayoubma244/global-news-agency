// Prisma schema for Automated News Website
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Admin Users =====
model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("admin") // admin | super_admin | editor
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ===== Categories (3-level hierarchy) =====
model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String
  nameFr      String
  nameEs      String
  icon        String?
  description String?
  parentId    String?  // null = main category; else points to parent
  level       Int      @default(1) // 1=main, 2=sub, 3=sub-sub
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  priority    String   @default("Medium") // Breaking | High | Medium | Low
  frequency   String?  // e.g. "8/day"
  seoKeywords String?  // comma separated
  tags        String?
  dataSources String?
  templateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")
  articles Article[]
}

// ===== Articles =====
model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleAr     String
  titleEn     String?
  leadAr      String?
  leadEn      String?
  bodyAr      String
  bodyEn      String?
  excerpt     String?
  featuredImg String?
  images      String?  // JSON array of image URLs
  categoryId  String
  sourceUrl   String?
  sourceName  String?
  author      String?
  status      String   @default("draft") // draft | published | scheduled | archived
  isBreaking  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  views       Int      @default(0)
  shares      Int      @default(0)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  viewEvents ArticleView[]
  tags      ArticleTag[]
}

// ===== Pages (CMS) =====
model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleAr     String
  titleEn     String?
  contentAr   String
  contentEn   String?
  template    String   @default("default") // default | about | contact | privacy | terms
  isPublished Boolean  @default(true)
  showInMenu  Boolean  @default(false)
  order       Int      @default(0)
  seoTitle       String?
  seoDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Site Settings =====
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("text") // text | textarea | boolean | number | json | password
  group String @default("general") // general | seo | social | api | theme | advanced
  label String?
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== API Keys (for news aggregation) =====
model ApiKey {
  id         String   @id @default(cuid())
  name       String
  provider   String   // newsapi | openweather | google_trends | twitter | coingecko | etc.
  apiKey     String
  apiSecret  String?
  endpoint   String?
  isActive   Boolean  @default(true)
  dailyLimit Int?
  usedToday  Int      @default(0)
  lastUsedAt DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ===== Automation Jobs (logs) =====
model AutomationLog {
  id         String   @id @default(cuid())
  stage      String   // trend_discovery | source_aggregation | ai_rewriter | fact_check | seo | publish | distribute
  status     String   // success | error | pending
  message    String?
  details    String?  // JSON
  durationMs Int?
  createdAt  DateTime @default(now())
}

// ===== Install Lock (one-time setup marker) =====
model InstallLock {
  id           String   @id @default(cuid())
  isInstalled  Boolean  @default(false)
  installedAt  DateTime?
  version      String   @default("1.0.0")
  adminUserId  String?
}

// ===== Tags =====
model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  count     Int      @default(0)
  createdAt DateTime @default(now())

  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

// ===== Newsletter Subscribers =====
model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  isVerified  Boolean  @default(false)
  verifyToken String?
  preferences String?  // JSON of category IDs
  language    String   @default("ar")
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Activity Logs (Audit Trail) =====
model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  adminName String?
  action    String   // create | update | delete | login | logout | publish | etc.
  entity    String   // article | category | page | setting | api_key | admin
  entityId  String?
  entityName String?
  details   String?  // JSON
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

// ===== Scheduled Jobs =====
model ScheduledJob {
  id          String   @id @default(cuid())
  name        String
  type        String   // automation_run | newsletter_send | sitemap_ping | etc.
  cron        String   // e.g. "0 * * * *" (every hour)
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String?  // success | error
  lastError   String?
  runCount    Int      @default(0)
  config      String?  // JSON of options
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Article Views (for analytics) =====
model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())
  country   String?
  device    String?  // mobile | desktop | tablet
  source    String?  // direct | search | social | referral

  @@index([articleId])
  @@index([viewedAt])
}
