// Prisma schema for Automated News Website
generator client {
  provider = "prisma-client-js"
}

// Production: PostgreSQL (Neon, Vercel Postgres, Supabase)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Admin Users =====
model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("admin") // admin | super_admin | editor
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ===== Categories (3-level hierarchy) =====
model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String
  nameFr      String
  nameEs      String
  icon        String?
  description String?
  parentId    String?  // null = main category; else points to parent
  level       Int      @default(1) // 1=main, 2=sub, 3=sub-sub
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  priority    String   @default("Medium") // Breaking | High | Medium | Low
  frequency   String?  // e.g. "8/day"
  seoKeywords String?  // comma separated
  tags        String?
  dataSources String?
  templateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")
  articles Article[]
  rssSources RssSource[]
}

// ===== Articles =====
model Article {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleAr     String
  titleEn     String?
  leadAr      String?
  leadEn      String?
  bodyAr      String
  bodyEn      String?
  excerpt     String?
  featuredImg String?
  categoryId  String
  sourceUrl   String?
  sourceName  String?
  author      String?
  status      String   @default("draft") // draft | published | scheduled | archived | needs_review
  isBreaking  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  views       Int      @default(0)
  shares      Int      @default(0)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Performance indexes
  @@index([status, publishedAt(sort: Desc)])
  @@index([categoryId, status])
  @@index([isBreaking, status])
  @@index([isFeatured, status])
  @@index([sourceUrl])
  @@index([rssSourceId])
  @@index([createdAt(sort: Desc)])

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  viewEvents ArticleView[]
  tags      ArticleTag[]
  images    ArticleImage[]
  rssSource RssSource? @relation("RssArticles", fields: [rssSourceId], references: [id], onDelete: SetNull)
  rssSourceId String?

  // New relations
  summary       ArticleSummary?
  comments      Comment[]
  reactions     Reaction[]
  bookmarks     Bookmark[]
  readingHistory ReadingHistory[]
  versions      ArticleVersion[]
  visitors      SiteVisitor[]
  liveUpdates   LiveUpdate[]

  // AI generation metadata
  aiToneUsed      String?
  aiLengthUsed    String?
  aiModel         String?
  plagiarismScore Float?   // 0-100 (lower = more unique)
  humanScore      Float?   // 0-100 (higher = more human-like)
  factCheckNotes  String?
}

// ===== Pages (CMS) =====
model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleAr     String
  titleEn     String?
  contentAr   String
  contentEn   String?
  template    String   @default("default") // default | about | contact | privacy | terms
  isPublished Boolean  @default(true)
  showInMenu  Boolean  @default(false)
  order       Int      @default(0)
  seoTitle       String?
  seoDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Site Settings =====
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("text") // text | textarea | boolean | number | json | password
  group String @default("general") // general | seo | social | api | theme | advanced
  label String?
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== API Keys (for news aggregation) =====
model ApiKey {
  id         String   @id @default(cuid())
  name       String
  provider   String   // newsapi | openweather | google_trends | twitter | coingecko | etc.
  apiKey     String
  apiSecret  String?
  endpoint   String?
  isActive   Boolean  @default(true)
  dailyLimit Int?
  usedToday  Int      @default(0)
  lastUsedAt DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ===== RSS Sources =====
model RssSource {
  id              String   @id @default(cuid())
  name            String
  url             String   @unique
  siteName        String?  // اسم الموقع الأصلي
  siteUrl         String?  // رابط الموقع الأصلي
  categoryId      String?
  language        String   @default("ar") // ar | en | fr | es
  isActive        Boolean  @default(true)
  lastFetchedAt   DateTime?
  lastFetchStatus String?  // success | error
  lastError       String?
  articlesCount   Int      @default(0)
  fetchInterval   Int      @default(60) // دقائق
  tags            String?  // comma-separated tags to add
  autoPublish     Boolean  @default(false)
  aiTone          String   @default("professional") // professional | casual | analytical | breaking | story
  aiLength        String   @default("medium") // short | medium | long
  includeImages   Boolean  @default(true)
  watermarkImages Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category   Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  articles   Article[]  @relation("RssArticles")
}

// ===== Article Images (with watermark info) =====
model ArticleImage {
  id          String  @id @default(cuid())
  articleId   String
  article     Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  originalUrl String
  storedUrl   String? // بعد التحميل + العلامة المائية
  caption     String?
  altText     String?
  width       Int?
  height      Int?
  isFeatured  Boolean @default(false)
  isWatermarked Boolean @default(false)
  order       Int     @default(0)
  createdAt   DateTime @default(now())
}

// ===== Automation Jobs (logs) =====
model AutomationLog {
  id         String   @id @default(cuid())
  stage      String   // trend_discovery | source_aggregation | ai_rewriter | fact_check | seo | publish | distribute
  status     String   // success | error | pending
  message    String?
  details    String?  // JSON
  durationMs Int?
  createdAt  DateTime @default(now())
}

// ===== Install Lock (one-time setup marker) =====
model InstallLock {
  id           String   @id @default(cuid())
  isInstalled  Boolean  @default(false)
  installedAt  DateTime?
  version      String   @default("1.0.0")
  adminUserId  String?
}

// ===== Tags =====
model Tag {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  count     Int      @default(0)
  createdAt DateTime @default(now())

  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

// ===== Newsletter Subscribers =====
model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  isVerified  Boolean  @default(false)
  verifyToken String?
  preferences String?  // JSON of category IDs
  language    String   @default("ar")
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Activity Logs (Audit Trail) =====
model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  adminName String?
  action    String   // create | update | delete | login | logout | publish | etc.
  entity    String   // article | category | page | setting | api_key | admin
  entityId  String?
  entityName String?
  details   String?  // JSON
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

// ===== Scheduled Jobs =====
model ScheduledJob {
  id          String   @id @default(cuid())
  name        String
  type        String   // automation_run | newsletter_send | sitemap_ping | etc.
  cron        String   // e.g. "0 * * * *" (every hour)
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastStatus  String?  // success | error
  lastError   String?
  runCount    Int      @default(0)
  config      String?  // JSON of options
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Article Views (for analytics) =====
model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())
  country   String?
  device    String?  // mobile | desktop | tablet
  source    String?  // direct | search | social | referral

  @@index([articleId])
  @@index([viewedAt])
}

// ===== Live Blog Updates =====
model LiveUpdate {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String
  type      String   @default("update") // update | key_event | breaking | summary
  isPinned  Boolean  @default(false)
  author    String?
  createdAt DateTime @default(now())

  @@index([articleId, createdAt(sort: Desc)])
}

// ===== Article AI Summary (TL;DR) =====
model ArticleSummary {
  id          String   @id @default(cuid())
  articleId   String   @unique
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  summaryAr   String   // 2-3 جمل
  summaryEn   String?
  keyPoints   String?  // JSON array of bullet points
  readingTime Int?     // بالدقائق
  readabilityScore Float? // 0-100
  clickbaitScore   Float? // 0-100 (الأقل أفضل)
  sentiment  String?  // positive | negative | neutral
  aiModel    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ===== Comments =====
model Comment {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorName String
  authorEmail String?
  content   String
  parentId  String?  // for replies
  status    String   @default("pending") // pending | approved | rejected | spam
  aiModerationScore Float? // 0-100 (الأعلى = آمن)
  aiToxicityScore Float? // 0-100 (الأعلى = سام)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies Comment[] @relation("CommentReplies")
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

// ===== Reactions =====
model Reaction {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  type      String   // like | love | wow | sad | angry
  sessionId String   // anonymous user identifier
  createdAt DateTime @default(now())

  @@unique([articleId, sessionId, type])
  @@index([articleId])
}

// ===== Bookmarks (Save for later) =====
model Bookmark {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sessionId String
  createdAt DateTime @default(now())

  @@unique([articleId, sessionId])
  @@index([sessionId])
}

// ===== Reading History =====
model ReadingHistory {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  sessionId String
  readProgress Float? // 0-100 (نسبة القراءة)
  readingTime Int?    // ثواني قضاها في القراءة
  viewedAt  DateTime @default(now())

  @@index([sessionId])
  @@index([articleId])
}

// ===== Ad Spaces =====
model AdSpace {
  id          String   @id @default(cuid())
  name        String
  position    String   // header | sidebar | in-article | footer | between-articles
  type        String   @default("banner") // banner | native | sponsored | adsense
  content     String?  // HTML/JS code
  imageUrl    String?
  linkUrl     String?
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== Article Versions (versioning) =====
model ArticleVersion {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  version   Int
  titleAr   String
  bodyAr    String
  editedBy  String?
  editNotes String?
  createdAt DateTime @default(now())

  @@index([articleId])
}

// ===== Real-time Visitors =====
model SiteVisitor {
  id        String   @id @default(cuid())
  sessionId String   @unique
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  ipAddress String?
  country   String?
  city      String?
  device    String?
  browser   String?
  referrer  String?
  lastActive DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([lastActive])
}
